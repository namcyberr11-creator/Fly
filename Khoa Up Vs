-- VÒNG LẶP XỬ LÝ
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character; if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    
    -- Xử lý Di chuyển (Ngay cả khi đang Ghim)
    if localMoveDir.Magnitude > 0 then
        root.Velocity = Vector3.zero
        local moveVec = (root.CFrame.LookVector * -localMoveDir.Z) + (root.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        root.CFrame = root.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt))
        -- Cập nhật lại Ghim khi đang di chuyển
        if ghimActive then lockedPos = root.CFrame end
    elseif ghimActive and lockedPos then
        -- Giữ nguyên vị trí nếu không bấm nút di chuyển
        root.CFrame = lockedPos
        root.Velocity = Vector3.zero
    end
    
    -- Fast Attack Aura
    if fastAttackActive then
        pcall(function()
            local net = rs.Modules.Net
            net["RE/RegisterAttack"]:FireServer(0)
            -- (Phần RegisterHit tự động gọi từ script FastMax)
        end)
    end
end)

