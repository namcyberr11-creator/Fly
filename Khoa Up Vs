local function GetBladeHits()
    local targets = {}
    for _, part in pairs({workspace.Enemies, workspace.Characters}) do
        for _, v in pairs(part:GetChildren()) do
            if v ~= lp.Character and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Head") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if (v.HumanoidRootPart.Position - lp.Character.HumanoidRootPart.Position).Magnitude < 65 then
                    table.insert(targets, v)
                end
            end
        end
    end
    return targets
end

local function ExecuteAttack()
    if not fastAttackActive or not lp.Character then return end
    local targets = GetBladeHits()
    if #targets > 0 then
        local net = rs:WaitForChild("Modules"):WaitForChild("Net")
        net["RE/RegisterAttack"]:FireServer(0)
        local args = {nil, {}}
        for i, v in pairs(targets) do
            if not args[1] then args[1] = v.Head end
            args[2][i] = {v, v.HumanoidRootPart}
        end
        net["RE/RegisterHit"]:FireServer(unpack(args))
    end
end

