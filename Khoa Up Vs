local function CreateBtn(parent, text, callback)
    local Btn = Instance.new("TextButton", parent); Btn.Size = UDim2.new(0.92, 0, 0, 32); Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Btn.Text = ""
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 5)
    local Square = Instance.new("Frame", Btn); Square.Size = UDim2.new(0, 14, 0, 14); Square.Position = UDim2.new(0, 8, 0.5, -7); Square.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Square.BorderSizePixel = 0
    Instance.new("UICorner", Square).CornerRadius = UDim.new(0, 3)
    local Label = Instance.new("TextLabel", Btn); Label.Size = UDim2.new(1, -35, 1, 0); Label.Position = UDim2.new(0, 30, 0, 0); Label.BackgroundTransparency = 1; Label.Text = text; Label.Font = Enum.Font.Gotham; Label.TextColor3 = Color3.fromRGB(210, 210, 210); Label.TextSize = 12; Label.TextXAlignment = "Left"
    local active = false
    Btn.MouseButton1Click:Connect(function() 
        active = not active
        Square.BackgroundColor3 = active and Color3.fromRGB(0, 120, 255) or Color3.fromRGB(40, 40, 40)
        SendNotify(text, active and "Đã Bật" or "Đã Tắt")
        callback(active) 
    end)
end

