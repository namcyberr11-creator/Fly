local function CreateToggle(name, callback)
    local B = Instance.new("TextButton", Scroll); B.Size = UDim2.new(0.9,0,0,35); B.BackgroundColor3 = Color3.fromRGB(25,25,25); B.Text = name; B.TextColor3 = Color3.new(0.7,0.7,0.7); B.Font = Enum.Font.Gotham
    Instance.new("UICorner", B).CornerRadius = UDim.new(0,6)
    local active = false
    B.MouseButton1Click:Connect(function()
        active = not active
        B.TextColor3 = active and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
        B.BackgroundColor3 = active and Color3.fromRGB(40,40,40) or Color3.fromRGB(25,25,25)
        SendNotify(name, active and "Đã Kích Hoạt" or "Đã Hủy")
        callback(active)
    end)
end

