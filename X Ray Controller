GhimBtnObj.MouseButton1Click:Connect(function()
    ghimActive = not ghimActive
    local r = game.Players.LocalPlayer.Character.HumanoidRootPart
    if ghimActive then lockedPos = r.CFrame; GhimBtnObj.Text = "GHIM: BẬT" else lockedPos = nil; GhimBtnObj.Text = "GHIM: TẮT" end
end)

GhostBtnObj.MouseButton1Click:Connect(function()
    ghostActive = not ghostActive
    local char = game.Players.LocalPlayer.Character
    if ghostActive then
        char.Archivable = true; ghostModel = char:Clone(); ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false; v.Transparency = 0.5 end end
        ghostPos = char.HumanoidRootPart.Position; lockedPos = char.HumanoidRootPart.CFrame
        workspace.CurrentCamera.CameraSubject = ghostModel.Humanoid; GhostBtnObj.Text = "GHOST: BẬT"
    else
        if ghostModel then ghostModel:Destroy() end
        workspace.CurrentCamera.CameraSubject = char.Humanoid; GhostBtnObj.Text = "GHOST: TẮT"
    end
end)

AirWalkBtnObj.MouseButton1Click:Connect(function()
    airWalkActive = not airWalkActive
    if airWalkActive then
        airWalkPart = Instance.new("Part", workspace); airWalkPart.Size = Vector3.new(15, 1, 15)
        airWalkPart.Anchored = true; airWalkPart.Transparency = 0.6; airWalkPart.CanCollide = true; airWalkPart.Color = Color3.new(0,1,1)
        AirWalkBtnObj.Text = "AIRWALK: BẬT"
    else
        if airWalkPart then airWalkPart:Destroy() end; AirWalkBtnObj.Text = "AIRWALK: TẮT"
    end
end)

