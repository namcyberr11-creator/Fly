-- [ DRAG UI ]
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
uis.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- [ ICON TOGGLE BUTTON FUNCTION ]
local function createToggleBtn(text, default, callback)
    local btn = Instance.new("TextButton", ScrollFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    applyStyle(btn, 8)
    
    local state = default
    local iconOn, iconOff = "🔲", "🔳"
    
    local function updateText()
        btn.Text = (state and iconOn or iconOff) .. "  " .. text
        btn.TextColor3 = state and Color3.new(0, 1, 0.5) or Color3.new(1, 1, 1)
    end
    
    updateText()
    btn.MouseButton1Click:Connect(function()
        state = not state
        updateText()
        callback(state)
    end)
end

