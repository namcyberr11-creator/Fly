-- [[ LOGIC CẬP NHẬT - NOCLIP MOVE ]]
local currentSpeed, airWalkActive, ghimActive, ghostActive = 50, false, false, false
local ghostModel, ghostPos, airWalkPart = nil, Vector3.new(0,0,0), nil
local lockedPos = nil

SpeedInput.FocusLost:Connect(function() currentSpeed = tonumber(SpeedInput.Text) or 50 end)

game:GetService("RunService").Stepped:Connect(function()
    -- Hệ thống Noclip: Chỉ hoạt động khi đang di chuyển bằng script
    if localMoveDir.Magnitude > 0 or ghostActive then
        local char = game.Players.LocalPlayer.Character
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end
    end
end)

game:GetService("RunService").RenderStepped:Connect(function(dt)
    local char = game.Players.LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local camCF = workspace.CurrentCamera.CFrame
    local flatF = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
    local flatR = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit
    
    local moveVec = (flatF * -localMoveDir.Z) + (flatR * localMoveDir.X)
    local upVec = Vector3.new(0, 1, 0) * localMoveDir.Y

    if ghostActive and ghostModel then
        if localMoveDir.Magnitude > 0 then
            ghostPos = ghostPos + ((moveVec + upVec).Unit * currentSpeed * dt)
        end
        ghostModel.HumanoidRootPart.CFrame = ghostModel.HumanoidRootPart.CFrame:Lerp(CFrame.new(ghostPos), 0.2)
        if lockedPos then root.CFrame = lockedPos end
        root.Velocity = Vector3.new(0,0,0)
    elseif localMoveDir.Magnitude > 0 then
        -- DI CHUYỂN TRƯỢT MƯỢT + NOCLIP
        local direction = (moveVec * currentSpeed) + (upVec * currentSpeed)
        root.CFrame = root.CFrame:Lerp(root.CFrame + (direction * dt), 0.5) 
        if ghimActive then lockedPos = root.CFrame end
    elseif ghimActive and lockedPos then
        root.CFrame = lockedPos
        root.Velocity = Vector3.new(0,0,0)
    end

    if airWalkActive and airWalkPart then
        local target = ghostActive and ghostModel.HumanoidRootPart or root
        airWalkPart.Position = target.Position - Vector3.new(0, 3.5, 0)
    end
end)

-- [ UI DRAG & CLOSE LOGIC ]
local dragging, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
game:GetService("UserInputService").InputEnded:Connect(function() dragging = false end)

