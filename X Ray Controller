local function createMoveBtn(txt, vec)
    local btn = Instance.new("TextButton", ButtonsGrid)
    btn.Text = txt; btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); applyStyle(btn, 6)
    local act = false
    btn.MouseButton1Click:Connect(function()
        act = not act
        btn.BackgroundColor3 = act and Color3.fromRGB(0, 150, 200) or Color3.fromRGB(40, 40, 40)
        if act then localMoveDir = localMoveDir + vec else localMoveDir = localMoveDir - vec end
    end)
end
