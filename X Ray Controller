    if s and char then
        char.Archivable = true; ghostModel = char:Clone(); ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false; v.Transparency = 0.5 end end
        ghostPos = char.HumanoidRootPart.Position; lockedPos = char.HumanoidRootPart.CFrame
        workspace.CurrentCamera.CameraSubject = ghostModel:FindFirstChild("Humanoid")
    else
        if ghostModel then ghostModel:Destroy() ghostModel = nil end
        if char then workspace.CurrentCamera.CameraSubject = char:FindFirstChild("Humanoid") end
    end
end)

createToggleBtn("X-RAY (ESP)", false, function(s)
    xrayActive = s
end)

-- [[ LOGIC ]]
runService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Noclip Auto
    if localMoveDir.Magnitude > 0 or ghostActive then
        for _, v in pairs(char:GetChildren()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end

    -- Di chuyển Hướng Nhân Vật
    if ghostActive and ghostModel then
        if localMoveDir.Magnitude > 0 then
            local gRoot = ghostModel.HumanoidRootPart
            local gMove = (gRoot.CFrame.LookVector * -localMoveDir.Z) + (gRoot.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
            ghostPos = ghostPos + (gMove.Unit * currentSpeed * dt)
        end
        ghostModel.HumanoidRootPart.CFrame = ghostModel.HumanoidRootPart.CFrame:Lerp(CFrame.new(ghostPos) * (root.CFrame - root.CFrame.Position), 0.2)
        root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0)
    elseif localMoveDir.Magnitude > 0 then
        local moveVec = (root.CFrame.LookVector * -localMoveDir.Z) + (root.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        root.CFrame = root.CFrame + (moveVec.Unit * currentSpeed * dt)
        if ghimActive then lockedPos = root.CFrame end
    elseif ghimActive and lockedPos then
        root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0)
    end

    -- Air Walk
    if airWalkActive and airWalkPart then
        local target = ghostActive and ghostModel.HumanoidRootPart or root
        if math.abs(localMoveDir.Y) > 0 or airHeight == 0 then airHeight = target.Position.Y - 3.5 end
        airWalkPart.Position = Vector3.new(target.Position.X, airHeight, target.Position.Z)
    end
    
    -- X-Ray ESP Logic
    for _, player in pairs(game:GetService("Players"):GetPlayers()) do
        if player ~= lp and player.Character then
            local pChar = player.Character
            local highlight = pChar:FindFirstChild("VuKhoa_ESP")
            if xrayActive then
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "VuKhoa_ESP"
                    highlight.FillColor = Color3.new(1, 0, 0)
                    highlight.OutlineColor = Color3.new(1, 1, 1)
                    highlight.FillTransparency = 0.5
                    highlight.Parent = pChar
                end
            elseif highlight then
                highlight:Destroy()
            end
        end
    end
end)

