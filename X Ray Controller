SpeedInput.BackgroundColor3 = Color3.fromRGB(35,35,35); applyStyle(SpeedInput, 10)

-- [[ LOGIC PISTON & NOCLIP ]]
local currentSpeed, ghimActive, ghostActive = 50, false, false
local ghostModel, ghostPos, downPiston = nil, Vector3.new(0,0,0), nil
local lockedPos = nil

SpeedInput.FocusLost:Connect(function() currentSpeed = tonumber(SpeedInput.Text) or 50 end)

-- Vòng lặp Noclip và Piston
game:GetService("RunService").Stepped:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart

    -- 1. Xử lý Noclip khi di chuyển
    if localMoveDir.Magnitude > 0 or ghostActive then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- 2. Xử lý PISTON ĐÈ ĐẦU (Khi bấm nút XUỐNG)
    if localMoveDir.Y < 0 then
        if not downPiston then
            downPiston = Instance.new("Part")
            downPiston.Name = "VuKhoa_Piston"
            downPiston.Size = Vector3.new(6, 1, 6)
            downPiston.Transparency = 0.8
            downPiston.Color = Color3.fromRGB(255, 0, 0)
            downPiston.Anchored = true
            downPiston.CanCollide = true -- Phải để true để nó đè được đầu
            downPiston.Parent = workspace
        end
        -- Luôn đặt miếng nhựa ngay sát phía trên đầu để ép xuống
        downPiston.CFrame = root.CFrame * CFrame.new(0, 2.8, 0)
    else
        if downPiston then downPiston:Destroy(); downPiston = nil end
    end
end)

game:GetService("RunService").RenderStepped:Connect(function(dt)
    local char = game.Players.LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local camCF = workspace.CurrentCamera.CFrame
    local flatF = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
    local flatR = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit
    
    local moveVec = (flatF * -localMoveDir.Z) + (flatR * localMoveDir.X)
    local upVec = Vector3.new(0, 1, 0) * localMoveDir.Y

    if ghostActive and ghostModel then
        if localMoveDir.Magnitude > 0 then
            ghostPos = ghostPos + ((moveVec + upVec).Unit * currentSpeed * dt)
        end
        ghostModel.HumanoidRootPart.CFrame = ghostModel.HumanoidRootPart.CFrame:Lerp(CFrame.new(ghostPos), 0.2)
        if lockedPos then root.CFrame = lockedPos end
        root.Velocity = Vector3.new(0,0,0)
    elseif localMoveDir.Magnitude > 0 then
        -- DI CHUYỂN TRƯỢT MƯỢT
        local direction = (moveVec * currentSpeed) + (upVec * currentSpeed)
        root.CFrame = root.CFrame:Lerp(root.CFrame + (direction * dt), 0.5) 
        if ghimActive then lockedPos = root.CFrame end
    elseif ghimActive and lockedPos then
        root.CFrame = lockedPos
        root.Velocity = Vector3.new(0,0,0)
    end
end)

