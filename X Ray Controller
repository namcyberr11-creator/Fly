local UIGrid = Instance.new("UIGridLayout", ButtonsGrid)
UIGrid.CellSize = UDim2.new(0.48, 0, 0, 40)

local localMoveDir = Vector3.new(0,0,0)
local function createMoveBtn(txt, vec)
    local btn = Instance.new("TextButton", ButtonsGrid)
    btn.Text = txt; btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35); applyStyle(btn, 10)
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(35, 35, 35)
        if active then localMoveDir = localMoveDir + vec else localMoveDir = localMoveDir - vec end
    end)
end

createMoveBtn("TIẾN", Vector3.new(0,0,-1)); createMoveBtn("LÙI", Vector3.new(0,0,1))
createMoveBtn("TRÁI", Vector3.new(-1,0,0)); createMoveBtn("PHẢI", Vector3.new(1,0,0))
createMoveBtn("LÊN", Vector3.new(0,1,0)); createMoveBtn("XUỐNG", Vector3.new(0,-1,0))

