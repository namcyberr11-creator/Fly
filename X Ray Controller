local function applyStyle(obj, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = obj
    if obj:IsA("TextButton") or obj:IsA("TextBox") then
        obj.Font = Enum.Font.GothamBold; obj.TextColor3 = Color3.new(1,1,1)
    end
end

