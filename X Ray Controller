-- [[ VŨ KHOA V31 PRO - AUTO NOCLIP SYNC ]]
-- Update: Chỉ đóng/mở được khi nhấn vào thanh tiêu đề (Chữ & Icon)
local lp = game:GetService("Players").LocalPlayer
local runService = game:GetService("RunService")
local uis = game:GetService("UserInputService")

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "TrVuKhoaa_Sync_UI"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ResetOnSpawn = false

-- Biến Logic
local localMoveDir = Vector3.new(0,0,0)
local currentSpeed = 1 
local ghimActive, xrayActive, ghostActive, airWalkActive = false, false, false, false
local lockedPos, airWalkPart, ghostModel = nil, nil, nil

-- Main Frame (Góc bên phải)
local MainFrame = Instance.new("Frame")
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
MainFrame.Position = UDim2.new(1, -240, 0.3, 0)
MainFrame.Size = UDim2.new(0, 220, 0, 380)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true

-- Title Bar (Nút bấm duy nhất để đóng/mở)
local TitleBar = Instance.new("TextButton")
TitleBar.Size = UDim2.new(1, 0, 0, 40)
TitleBar.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
TitleBar.Text = "  ▼   TrVũKhoaa"
TitleBar.Font = Enum.Font.Antique
TitleBar.TextColor3 = Color3.new(1, 1, 1)
TitleBar.TextSize = 22
TitleBar.TextXAlignment = Enum.TextXAlignment.Left
TitleBar.Parent = MainFrame
TitleBar.BorderSizePixel = 0
TitleBar.AutoButtonColor = false

-- [[ LOGIC KÉO THẢ & CLICK ]]
local dragging, dragStart, startPos
local wasDragging = false
local isOpen = true

local Content = Instance.new("Frame", MainFrame)
Content.Size = UDim2.new(1, 0, 1, -40); Content.Position = UDim2.new(0, 0, 0, 40); Content.BackgroundTransparency = 1

-- Bắt đầu kéo
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        wasDragging = false
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

-- Đang kéo
uis.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        if delta.Magnitude > 5 then wasDragging = true end
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Kết thúc kéo
uis.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- CHỈ ĐÓNG/MỞ KHI NHẤN VÀO TITLEBAR
TitleBar.MouseButton1Click:Connect(function()
    if not wasDragging then
        isOpen = not isOpen
        Content.Visible = isOpen
        MainFrame.Size = isOpen and UDim2.new(0, 220, 0, 380) or UDim2.new(0, 220, 0, 40)
        TitleBar.Text = isOpen and "  ▼   TrVũKhoaa" or "  ▶   TrVũKhoaa"
    end
end)

-- [Các chức năng chức năng giữ nguyên]
local function createBtn(parent, txt, isGrid, callback)
    local btn = Instance.new("TextButton", parent)
    if not isGrid then btn.Size = UDim2.new(1, 0, 0, 32) end
    btn.BackgroundTransparency = 1; btn.Text = ""
    local box = Instance.new("Frame", btn)
    box.Size = UDim2.new(0, 24, 0, 28); box.Position = UDim2.new(0, 0, 0.5, -14); box.BackgroundColor3 = Color3.fromRGB(18, 18, 18); box.BorderSizePixel = 0
    local lbl = Instance.new("TextLabel", btn)
    lbl.Size = UDim2.new(1, -35, 1, 0); lbl.Position = UDim2.new(0, 35, 0, 0); lbl.BackgroundTransparency = 1; lbl.Text = txt; lbl.Font = Enum.Font.Antique; lbl.TextColor3 = Color3.new(0.9, 0.9, 0.9); lbl.TextSize = 20; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        box.BackgroundColor3 = active and Color3.fromRGB(150, 150, 150) or Color3.fromRGB(18, 18, 18)
        callback(active)
    end)
end

local Grid = Instance.new("Frame", Content)
Grid.Position = UDim2.new(0, 20, 0, 15); Grid.Size = UDim2.new(1, -40, 0, 110); Grid.BackgroundTransparency = 1
local UIGrid = Instance.new("UIGridLayout", Grid); UIGrid.CellSize = UDim2.new(0.48, 0, 0, 32); UIGrid.CellPadding = UDim2.new(0.04, 0, 0, 5)
local moves = {{"Tiến", Vector3.new(0,0,-1)}, {"Lùi", Vector3.new(0,0,1)}, {"Trái", Vector3.new(-1,0,0)}, {"Phải", Vector3.new(1,0,0)}, {"Lên", Vector3.new(0,1,0)}, {"Xuống", Vector3.new(0,-1,0)}}
for _, v in pairs(moves) do createBtn(Grid, v[1], true, function(s) if s then localMoveDir = localMoveDir + v[2] else localMoveDir = localMoveDir - v[2] end end) end

local List = Instance.new("Frame", Content)
List.Position = UDim2.new(0, 20, 0, 140); List.Size = UDim2.new(1, -40, 0, 150); List.BackgroundTransparency = 1
local UIList = Instance.new("UIListLayout", List); UIList.Padding = UDim.new(0, 8)
createBtn(List, "Ghim Pos", false, function(s) ghimActive = s; if s and lp.Character then lockedPos = lp.Character.HumanoidRootPart.CFrame end end)
createBtn(List, "Xray ESP", false, function(s) xrayActive = s end)
createBtn(List, "Ghost Mode", false, function(s)
    ghostActive = s
    if s and lp.Character then
        lp.Character.Archivable = true
        ghostModel = lp.Character:Clone(); ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false; v.Transparency = 0.5 end end
        workspace.CurrentCamera.CameraSubject = ghostModel:FindFirstChild("Humanoid")
    elseif ghostModel then ghostModel:Destroy(); workspace.CurrentCamera.CameraSubject = lp.Character.Humanoid end
end)
createBtn(List, "Air Walk", false, function(s)
    airWalkActive = s
    if s then airWalkPart = Instance.new("Part", workspace); airWalkPart.Size = Vector3.new(15, 0.5, 15); airWalkPart.Anchored = true; airWalkPart.Transparency = 0.5
    elseif airWalkPart then airWalkPart:Destroy() end
end)

local SpeedBar = Instance.new("Frame", Content)
SpeedBar.Size = UDim2.new(1, 0, 0, 45); SpeedBar.Position = UDim2.new(0, 0, 1, -45); SpeedBar.BackgroundColor3 = Color3.fromRGB(12, 12, 12); SpeedBar.BorderSizePixel = 0
local BlueSq = Instance.new("Frame", SpeedBar); BlueSq.Size = UDim2.new(0, 32, 0, 32); BlueSq.Position = UDim2.new(0, 20, 0.5, -16); BlueSq.BackgroundColor3 = Color3.fromRGB(75, 115, 255); BlueSq.BorderSizePixel = 0
local SpeedVal = Instance.new("TextBox", SpeedBar); SpeedVal.Text = "1"; SpeedVal.Size = UDim2.new(0.5, 0, 1, 0); SpeedVal.Position = UDim2.new(0, 65, 0, 0); SpeedVal.BackgroundTransparency = 1; SpeedVal.Font = Enum.Font.Antique; SpeedVal.TextColor3 = Color3.new(1, 1, 1); SpeedVal.TextSize = 24; SpeedVal.TextXAlignment = Enum.TextXAlignment.Left
SpeedVal.FocusLost:Connect(function() currentSpeed = tonumber(SpeedVal.Text) or 1 end)
local TocLbl = Instance.new("TextLabel", SpeedBar); TocLbl.Text = "Tốc"; TocLbl.Size = UDim2.new(0, 40, 1, 0); TocLbl.Position = UDim2.new(1, -60, 0, 0); TocLbl.BackgroundTransparency = 1; TocLbl.Font = Enum.Font.Antique; TocLbl.TextColor3 = Color3.new(1, 1, 1); TocLbl.TextSize = 22

runService.Heartbeat:Connect(function(dt)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart
    if xrayActive then
        for _, p in pairs(game.Players:GetPlayers()) do
            if p ~= lp and p.Character then
                if not p.Character:FindFirstChild("TrVuKhoaa_ESP") then
                    local h = Instance.new("Highlight", p.Character); h.Name = "TrVuKhoaa_ESP"; h.FillColor = Color3.new(1, 0, 0)
                end
            end
        end
    else
        for _, p in pairs(game.Players:GetPlayers()) do if p.Character and p.Character:FindFirstChild("TrVuKhoaa_ESP") then p.Character.TrVuKhoaa_ESP:Destroy() end end
    end
    local target = (ghostActive and ghostModel) and ghostModel:FindFirstChild("HumanoidRootPart") or root
    if localMoveDir.Magnitude > 0 then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
        if ghostModel then for _, v in pairs(ghostModel:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end end
        local moveVec = (target.CFrame.LookVector * -localMoveDir.Z) + (target.CFrame.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)
        target.CFrame = target.CFrame + (moveVec.Unit * (currentSpeed * 50 * dt))
        if ghimActive and not ghostActive then lockedPos = target.CFrame end
    end
    if ghimActive and lockedPos and not ghostActive then root.CFrame = lockedPos; root.Velocity = Vector3.new(0,0,0) end
    if ghostActive then root.CFrame = lockedPos or root.CFrame; root.Velocity = Vector3.new(0,0,0) end
    if airWalkActive and airWalkPart then airWalkPart.Position = target.Position - Vector3.new(0, 3.5, 0) end
end)
