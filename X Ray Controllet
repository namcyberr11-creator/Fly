-- [[ LOGIC ]]
local currentSpeed, airWalkActive, ghimActive, ghostActive = 50, false, false, false
local airWalkPart, ghostModel, ghostPos = nil, nil, Vector3.new(0,0,0)
local lockedPos = nil
local camera = workspace.CurrentCamera

SpeedInput.FocusLost:Connect(function()
    local val = tonumber(SpeedInput.Text)
    if val then currentSpeed = val else SpeedInput.Text = tostring(currentSpeed) end
end)

AirWalkBtnObj.MouseButton1Click:Connect(function()
    airWalkActive = not airWalkActive
    local lp = game.Players.LocalPlayer.Character
    if airWalkActive and lp and lp:FindFirstChild("HumanoidRootPart") then
        airWalkPart = Instance.new("Part", workspace)
        airWalkPart.Name = "VuKhoa_AirWalk"
        airWalkPart.Size = Vector3.new(12, 1, 12)
        airWalkPart.Transparency = 0.6; airWalkPart.Color = Color3.fromRGB(0, 255, 150)
        airWalkPart.Anchored = true; airWalkPart.CanCollide = true
        AirWalkBtnObj.Text = "AIR WALK: BẬT"
    else
        if airWalkPart then airWalkPart:Destroy() end
        AirWalkBtnObj.Text = "AIR WALK: TẮT"
        airWalkActive = false
    end
end)

GhimBtnObj.MouseButton1Click:Connect(function()
    ghimActive = not ghimActive
    local char = game.Players.LocalPlayer.Character
    if ghimActive and char and char:FindFirstChild("HumanoidRootPart") then
        lockedPos = char.HumanoidRootPart.CFrame
        GhimBtnObj.Text = "GHIM VỊ TRÍ: BẬT"
    else
        lockedPos = nil
        GhimBtnObj.Text = "GHIM VỊ TRÍ: TẮT"
    end
end)

GhostBtnObj.MouseButton1Click:Connect(function()
    ghostActive = not ghostActive
    local char = game.Players.LocalPlayer.Character
    if ghostActive and char and char:FindFirstChild("HumanoidRootPart") then
        char.Archivable = true
        ghostModel = char:Clone()
        ghostModel.Parent = workspace
        for _, v in pairs(ghostModel:GetDescendants()) do 
            if v:IsA("BasePart") then v.CanCollide = false; v.Transparency = 0.5 end 
        end
        ghostPos = char.HumanoidRootPart.Position
        lockedPos = char.HumanoidRootPart.CFrame
        camera.CameraSubject = ghostModel:FindFirstChildOfClass("Humanoid")
        GhostBtnObj.Text = "GHOST MODE: BẬT"
    else
        if ghostModel then ghostModel:Destroy() end
        if char then camera.CameraSubject = char:FindFirstChildOfClass("Humanoid") end
        GhostBtnObj.Text = "GHOST MODE: TẮT"
        ghostActive = false
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
