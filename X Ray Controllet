local localMoveDir = Vector3.new(0,0,0)
local function createMoveBtn(txt, vec)
    local btn = Instance.new("TextButton", ButtonsGrid)
    btn.Text = txt
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    applyStyle(btn, 10)
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        btn.BackgroundColor3 = active and Color3.fromRGB(0, 160, 100) or Color3.fromRGB(30, 30, 30)
        if active then localMoveDir = localMoveDir + vec else localMoveDir = localMoveDir - vec end
    end)
end

