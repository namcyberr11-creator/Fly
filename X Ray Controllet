-- [[ CHẠY HỆ THỐNG ]]
game:GetService("RunService").RenderStepped:Connect(function(dt)
    local char = game.Players.LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local root = char.HumanoidRootPart
    local camCF = camera.CFrame
    local worldMoveVector = (camCF.LookVector * -localMoveDir.Z) + (camCF.RightVector * localMoveDir.X) + (Vector3.new(0,1,0) * localMoveDir.Y)

    if ghostActive and ghostModel then
        if localMoveDir.Magnitude > 0 then
            ghostPos = ghostPos + (worldMoveVector.Unit * currentSpeed * dt)
        end
        ghostModel.HumanoidRootPart.CFrame = CFrame.new(ghostPos)
        root.CFrame = lockedPos
        root.Velocity = Vector3.new(0,0,0)
    elseif localMoveDir.Magnitude > 0 then
        root.CFrame = root.CFrame + (worldMoveVector * currentSpeed * dt)
        if ghimActive then lockedPos = root.CFrame end
    elseif ghimActive and lockedPos then
        root.CFrame = lockedPos
        root.Velocity = Vector3.new(0,0,0)
    end

    if airWalkActive and airWalkPart then
        local target = (ghostActive and ghostModel) and ghostModel.HumanoidRootPart or root
        airWalkPart.Position = target.Position - Vector3.new(0, 3.2, 0)
    end
end)

