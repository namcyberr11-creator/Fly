local function CreateBtn(name, pos, var, isFunction, customFunc)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, 0, pos)
    btn.Text = name .. (not isFunction and ": OFF" or "")
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.Code
    btn.TextSize = 10

    btn.MouseButton1Click:Connect(function()
        if isFunction then
            if customFunc then customFunc() else pcall(function() LP.Character:BreakJoints() end) end
        else
            _G[var] = not _G[var]
            btn.Text = name .. ": " .. (_G[var] and "ON" or "OFF")
            btn.BackgroundColor3 = _G[var] and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(20, 20, 20)
        end
    end)
end

-- [HÀM XUỐNG ĐẤT SIÊU CẤP - FIX LỖI KHÔNG XUỐNG ĐƯỢC]
local function ForceGoDown()
    pcall(function()
        local char = LP.Character
        local hrp = char.HumanoidRootPart
        
        -- 1. Bật Noclip liên tục để đảm bảo không kẹt trần/sàn
        local noclipLoop = RunService.Stepped:Connect(function()
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end
        end)
        
        -- 2. Quét tìm mặt đất (Raycast diện rộng)
        local params = RaycastParams.new()
        params.FilterDescendantsInstances = {char, workspace.CurrentCamera}
        params.FilterType = Enum.RaycastFilterType.Blacklist
        
        -- Bắn tia từ trên cực cao xuống để tránh bị lọt tia qua khe hở
        local startPos = hrp.Position + Vector3.new(0, 50, 0)
        local result = workspace:Raycast(startPos, Vector3.new(0, -10000, 0), params)
        
        if result then
            -- 3. Ép tọa độ ngay lập tức
            hrp.CFrame = CFrame.new(result.Position + Vector3.new(0, 4, 0))
            hrp.Velocity = Vector3.new(0, 0, 0)
        else
            -- 4. Nếu không thấy mặt đất (lỗi map), ép về tọa độ Y mặc định của server
            hrp.CFrame = CFrame.new(hrp.Position.X, 10, hrp.Position.Z)
        end
        
        task.wait(0.3)
        noclipLoop:Disconnect() -- Tắt noclip sau khi đã đáp an toàn
    end)
end

