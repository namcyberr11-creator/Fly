-- [LOGIC GOD SKY - PHANTOM UP]
RunService.Stepped:Connect(function()
    if _G.GodSky and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LP.Character.HumanoidRootPart
        local oldCF = hrp.CFrame
        hrp.Velocity = Vector3.new(0, 0, 0)
        
        -- Tự động noclip khi đang ở trên trời
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end

        -- Nháy lên (Xuyên mọi nóc nhà)
        hrp.CFrame = oldCF * CFrame.new(0, _G.SkyHeight, 0)
        RunService.RenderStepped:Wait()
        hrp.CFrame = oldCF
    end
end)

